rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── contact_messages ──────────────────────────────────────────
    // Anyone can CREATE a new message (public contact form).
    // Only authenticated Firebase users (admins) can READ.
    // Nobody can UPDATE or DELETE.
    match /contact_messages/{docId} {
      allow create: if isValidContactMessage();
      allow read:   if request.auth != null;
      allow update, delete: if false;
    }

    // ── paper_submissions ──────────────────────────────────────────
    match /paper_submissions/{docId} {
      allow create: if true;
      allow read:   if request.auth != null;
      allow update, delete: if false;
    }

    // ── All other collections ─────────────────────────────────────
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Validation helper ─────────────────────────────────────────
    // Ensures submitted documents have the expected shape and
    // prevents spam / oversized payloads.
    function isValidContactMessage() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'submittedAt'])
        && data.name is string   && data.name.size()    > 0 && data.name.size()    <= 100
        && data.email is string  && data.email.size()   > 0 && data.email.size()   <= 200
        && data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000;
    }
  }
}
